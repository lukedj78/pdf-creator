# =============================================================================
# PDF Generator SaaS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Resend (transactional emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="PDF Generator <noreply@yourdomain.com>"
# Override recipient for all emails (useful for dev/staging)
EMAIL_OVERRIDE_TO=""

# -----------------------------------------------------------------------------
# Vercel AI Gateway (@ai-sdk/gateway)
# Uses https://ai-gateway.vercel.sh/v1/ai by default
# -----------------------------------------------------------------------------
AI_GATEWAY_API_KEY=""

# -----------------------------------------------------------------------------
# File Storage (Vercel Blob / S3 / R2)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting — production only)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SKIP_RATE_LIMIT="true"

# -----------------------------------------------------------------------------
# Polar (billing — Merchant of Record)
# Get these from https://polar.sh dashboard
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
POLAR_AI_METER_ID=""
POLAR_PRO_PRODUCT_ID=""
POLAR_ENTERPRISE_PRODUCT_ID=""
POLAR_CREDITS_100_PRODUCT_ID=""
POLAR_CREDITS_500_PRODUCT_ID=""
POLAR_CREDITS_1000_PRODUCT_ID=""
