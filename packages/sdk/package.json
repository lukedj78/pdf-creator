{
  "name": "@pdf-generator/sdk",
  "version": "0.1.0",
  "description": "SDK for SpecDesigner API — export JSON specs from templates programmatically",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": ["spec", "designer", "json", "sdk", "api", "template"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
